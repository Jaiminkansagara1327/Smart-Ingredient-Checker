# Django Security Settings
SECRET_KEY=your-secret-key-here-generate-new-one-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI API Key (optional - for AI-powered analysis)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Email Settings (for contact form notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
CONTACT_EMAIL_RECIPIENT=your-email@gmail.com

# CORS Settings (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production Settings (uncomment and configure for deployment)
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
