# Django Security Settings
# IMPORTANT: Copy this file to .env and fill in real values
# NEVER commit .env file to version control!

# Generate a new secret key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Set to False in production!
DEBUG=False

# Allowed hosts (comma-separated)
# Production example: example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (comma-separated)
# Production example: https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (for production PostgreSQL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ingrexa_db
# DB_USER=ingrexa_user
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Email Settings (for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
CONTACT_EMAIL_RECIPIENT=contact@yourdomain.com

# Security Settings (Production Only)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
